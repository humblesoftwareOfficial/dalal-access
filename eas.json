{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "android": {
        "buildType": "apk"
      },
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "preview"
    },
    "beta": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "beta"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "production"
      },
      "ios": {
        "appleId": "lamine.thiam@ldb.sn",
        "ascAppId": "VOTRE_ASC_APP_ID",
        "appleTeamId": "VOTRE_TEAM_ID"
      }
    }
  }
}