{
  "expo": {
    "name": "Dalal Access",
    "slug": "dalal-access",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#59329E"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.humblesoft.dalalaccess",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow $(PRODUCT_NAME) to access your camera."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#59329E"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.humblesoft.dalalaccess"
    },
    "androidNavigationBar": {
      "backgroundColor": "#FFFFFF",
      "barStyle": "dark-content"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera"
        }
      ],
      "expo-asset",
      "expo-font",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "notification": {
      "icon": "./assets/adaptive-icon.png"
    },
    "owner": "humblesoft",
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "774a464e-70e4-43c5-8a88-ae11fee377d2"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/774a464e-70e4-43c5-8a88-ae11fee377d2"
    }
  }
}
